{
  "info": {
    "name": "Farmers Market Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"admin@farmmarket.ci\",\n  \"password\": \"Admin1234!\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                { "key": "per_page", "value": "15", "disabled": true, "description": "Items per page (1–100, default: 15)" },
                { "key": "page",     "value": "1",  "disabled": true, "description": "Page number" }
              ]
            },
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Kouamé Dje\",\n  \"email\": \"operateur2@farmmarket.ci\",\n  \"password\": \"Oper1234!\",\n  \"role\": \"operator\"\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Konan Kouamé (updated)\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/users/4",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"],
              "query": [
                { "key": "per_page", "value": "15", "disabled": true, "description": "Items per page (1–100, default: 15)" },
                { "key": "page",     "value": "1",  "disabled": true, "description": "Page number" }
              ]
            },
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Category (root)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Épices et condiments\"\n}"
            }
          }
        },
        {
          "name": "Create Category (child)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Gingembre\",\n  \"parent_id\": 1\n}"
            }
          }
        },
        {
          "name": "Get Category",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Céréales et grains\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "per_page",   "value": "15", "disabled": true, "description": "Items per page (1–100, default: 15)" },
                { "key": "page",       "value": "1",  "disabled": true, "description": "Page number" },
                { "key": "category_id","value": "1",  "disabled": true, "description": "Filter by category ID" }
              ]
            },
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/products",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Fonio (sac 25 kg)\",\n  \"description\": \"Fonio blanc décortiqué, production du nord de la Côte d'Ivoire.\",\n  \"price\": 12000,\n  \"category_id\": 1\n}"
            }
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/products/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"price\": 8000\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/products/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Farmers",
      "item": [
        {
          "name": "List Farmers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/farmers",
              "host": ["{{base_url}}"],
              "path": ["farmers"],
              "query": [
                { "key": "per_page", "value": "15", "disabled": true, "description": "Items per page (1–100, default: 15)" },
                { "key": "page",     "value": "1",  "disabled": true, "description": "Page number" }
              ]
            },
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Farmer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/farmers",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"identifier\": \"CI-ABJ-00016\",\n  \"firstname\": \"Adjobi\",\n  \"lastname\": \"Kra Kouamé\",\n  \"phone\": \"+2250701234516\",\n  \"credit_limit\": 400000\n}"
            }
          }
        },
        {
          "name": "Get Farmer",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/farmers/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Farmer",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/farmers/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"credit_limit\": 750000\n}"
            }
          }
        },
        {
          "name": "Delete Farmer",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/farmers/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Farmer Outstanding Debts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/farmers/1/debts",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                { "key": "per_page",       "value": "15",         "disabled": true, "description": "Items per page (1–100, default: 15)" },
                { "key": "page",           "value": "1",          "disabled": true, "description": "Page number" },
                { "key": "farmer_id",      "value": "1",          "disabled": true, "description": "Filter by farmer ID" },
                { "key": "payment_method", "value": "credit",     "disabled": true, "description": "Filter by payment method: cash | credit" },
                { "key": "date_from",      "value": "2026-01-01", "disabled": true, "description": "Filter from date (YYYY-MM-DD)" },
                { "key": "date_to",        "value": "2026-12-31", "disabled": true, "description": "Filter to date (YYYY-MM-DD)" }
              ]
            },
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Transaction — Cash",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"farmer_id\": 1,\n  \"payment_method\": \"cash\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2,\n      \"unit_price\": 7500\n    },\n    {\n      \"product_id\": 3,\n      \"quantity\": 1,\n      \"unit_price\": 5500\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Transaction — Credit",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/transactions",
            "description": "interest_rate is optional. Omit it to use the server default (DEFAULT_INTEREST_RATE env, currently 0.10 = 10%). Provide it to override per-transaction.",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"farmer_id\": 2,\n  \"payment_method\": \"credit\",\n  \"interest_rate\": 0.10,\n  \"items\": [\n    {\n      \"product_id\": 5,\n      \"quantity\": 3,\n      \"unit_price\": 3500\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/transactions/1",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Repayments",
      "item": [
        {
          "name": "Record Repayment",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/repayments",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"farmer_id\": 2,\n  \"kg_received\": 25,\n  \"commodity_rate\": 450\n}"
            }
          }
        }
      ]
    }
  ]
}
